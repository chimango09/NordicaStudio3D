
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the user account was created."
        }
      },
      "required": [
        "createdAt"
      ]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Represents a client who orders 3D printed products.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the client."
        },
        "email": {
          "type": "string",
          "description": "Email address of the client.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the client."
        },
        "address": {
          "type": "string",
          "description": "Address of the client."
        }
      },
      "required": [
        "name"
      ]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Represents an expense related to 3D printing, such as filament or accessories.",
      "properties": {
        "date": {
          "type": "string",
          "description": "Date of the expense.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the expense."
        },
        "amount": {
          "type": "number",
          "description": "Amount of the expense."
        }
      },
      "required": [
        "date",
        "amount"
      ]
    },
    "Filament": {
      "title": "Filament",
      "type": "object",
      "description": "Represents a type of filament used for 3D printing.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the filament (e.g., PLA, ABS)."
        },
        "color": {
          "type": "string",
          "description": "Color of the filament."
        },
        "colorHex": {
          "type": "string",
          "description": "Hexadecimal color code for UI."
        },
        "stockLevel": {
          "type": "number",
          "description": "Current stock level of the filament (e.g., in grams)."
        },
        "costPerKg": {
          "type": "number",
          "description": "Cost per kilogram of the filament."
        },
        "spoolWeight": {
          "type": "number",
          "description": "The standard weight of a new spool for this filament (e.g., 750g, 1000g)."
        }
      },
      "required": [
        "name",
        "stockLevel",
        "costPerKg"
      ]
    },
    "Accessory": {
      "title": "Accessory",
      "type": "object",
      "description": "Represents an accessory that can be added to a print job, like lamps or cables.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the accessory."
        },
        "stockLevel": {
          "type": "number",
          "description": "Current stock level of the accessory."
        },
        "cost": {
          "type": "number",
          "description": "Cost of a single unit of the accessory."
        }
      },
      "required": [
        "name",
        "stockLevel",
        "cost"
      ]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a 3D printable piece/product with predefined costs and materials.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the piece."
        },
        "description": {
          "type": "string",
          "description": "Description of the piece."
        },
        "printingTimeHours": {
          "type": "number",
          "description": "Standard printing time in hours."
        },
        "profitMargin": {
          "type": "number",
          "description": "Default profit margin percentage."
        },
        "materials": {
          "type": "array",
          "description": "Predefined filaments used.",
          "items": {
            "type": "object",
            "properties": {
              "filamentId": { "type": "string" },
              "grams": { "type": "number" }
            }
          }
        },
        "accessories": {
          "type": "array",
          "description": "Predefined accessories used.",
          "items": {
            "type": "object",
            "properties": {
              "accessoryId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "price": {
          "type": "number",
          "description": "Standard price for the piece."
        },
        "materialCost": { "type": "number" },
        "accessoryCost": { "type": "number" },
        "machineCost": { "type": "number" },
        "electricityCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price"]
    },
    "Quote": {
      "title": "Quote",
      "type": "object",
      "description": "Represents a quote for a 3D printing job.",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Reference to Client."
        },
        "date": {
          "type": "string",
          "description": "Date the quote was created.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the print job."
        },
        "materials": {
          "type": "array",
          "description": "List of filaments used in the job.",
          "items": {
            "type": "object",
            "properties": {
              "filamentId": {
                "type": "string"
              },
              "grams": {
                "type": "number"
              }
            },
            "required": [
              "filamentId",
              "grams"
            ]
          }
        },
        "accessories": {
          "type": "array",
          "description": "List of accessories used in the job.",
          "items": {
            "type": "object",
            "properties": {
              "accessoryId": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              }
            },
            "required": [
              "accessoryId",
              "quantity"
            ]
          }
        },
        "printingTimeHours": {
          "type": "number",
          "description": "Estimated printing time in hours."
        },
        "profitMargin": {
          "type": "number",
          "description": "Profit margin used for this specific quote."
        },
        "price": {
          "type": "number",
          "description": "Total price of the quote."
        },
        "status": {
          "type": "string",
          "description": "The status of the quote.",
          "enum": [
            "Pendiente",
            "Imprimiendo",
            "Listo",
            "Entregado"
          ]
        },
        "materialCost": {
          "type": "number",
          "description": "Total cost of all materials (filaments) for the job."
        },
        "accessoryCost": {
          "type": "number",
          "description": "Total cost of all accessories for the job."
        },
        "machineCost": {
          "type": "number",
          "description": "Cost of machine usage for the job."
        },
        "electricityCost": {
          "type": "number",
          "description": "Cost of electricity for the job."
        }
      },
      "required": [
        "clientId",
        "date",
        "printingTimeHours",
        "price",
        "status",
        "materialCost",
        "accessoryCost",
        "machineCost",
        "electricityCost"
      ]
    },
    "Setting": {
      "title": "Setting",
      "type": "object",
      "description": "Represents a configuration setting for the application.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the setting (e.g., electricityCost, companyName, bankAlias)."
        },
        "value": {
          "type": "string",
          "description": "Value of the setting."
        }
      },
      "required": [
        "name",
        "value"
      ]
    },
    "TrashItem": {
      "title": "TrashItem",
      "type": "object",
      "description": "Represents an item that has been soft-deleted and moved to the trash.",
      "properties": {
        "originalId": {
          "type": "string",
          "description": "The original ID of the document before it was deleted."
        },
        "originalCollection": {
          "type": "string",
          "description": "The original collection from which the document was deleted."
        },
        "deletedAt": {
          "type": "string",
          "description": "The timestamp when the item was moved to the trash.",
          "format": "date-time"
        },
        "data": {
          "type": "object",
          "description": "A copy of the original document's data."
        }
      },
      "required": [
        "originalId",
        "originalCollection",
        "deletedAt",
        "data"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      }
    },
    "/users/{userId}/clients/{clientId}": {
      "schema": {
        "$ref": "#/entities/Client"
      }
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": {
        "$ref": "#/entities/Expense"
      }
    },
    "/users/{userId}/filaments/{filamentId}": {
      "schema": {
        "$ref": "#/entities/Filament"
      }
    },
    "/users/{userId}/accessories/{accessoryId}": {
      "schema": {
        "$ref": "#/entities/Accessory"
      }
    },
    "/users/{userId}/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      }
    },
    "/users/{userId}/quotes/{quoteId}": {
      "schema": {
        "$ref": "#/entities/Quote"
      }
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Setting"
      }
    },
    "/users/{userId}/trash/{trashId}": {
      "schema": {
        "$ref": "#/entities/TrashItem"
      }
    }
  }
}
